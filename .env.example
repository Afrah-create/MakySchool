# ── Platform ──────────────────────────────────────────────
NEXT_PUBLIC_ROOT_DOMAIN=makyschool.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── API (Express backend) ─────────────────────────────────
API_URL=http://localhost:4000
API_INTERNAL_URL=http://localhost:4000

# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://makyschool:makyschool@localhost:5432/makyschool

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────
JWT_SECRET=change-me-in-production

# ── Object storage ────────────────────────────────────────
STORAGE_BUCKET=makyschool
STORAGE_ENDPOINT=http://localhost:9000

# ── External integrations ─────────────────────────────────
SCHOOLPAY_WEBHOOK_SECRET=
MAKYREACH_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
