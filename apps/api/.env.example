# Database (MakySchool PostgreSQL - separate from auth)
DATABASE_URL=postgresql://user:password@localhost:5432/makyschool

# Auth Service Integration
AUTH_SERVICE_URL=http://localhost:8000
AUTH_JWT_SECRET=your-jwt-secret-change-in-production
JWT_ALGORITHM=HS256

# API Configuration
APP_NAME=MakySchool API
PORT=4000
API_INTERNAL_URL=http://localhost:4000
PLATFORM_APP_URL=http://localhost:3001

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8080,http://myschool.localhost:8080

# Features
SUBSCRIPTIONS_ENABLED=false
RUN_MIGRATIONS=true
